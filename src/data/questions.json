[
    {
        "id": 1,
        "text": "财富不平等的根源主要在于资本主义制度本身，而非个人不够努力。",
        "category": "经济福利",
        "weights": {
            "econ": -1.0,
            "soc": 0.0
        }
    },
    {
        "id": 2,
        "text": "富人之所以富有，绝大多数是因为他们具备卓越的才能并付出了更多努力。",
        "category": "经济福利",
        "weights": {
            "econ": 1.0,
            "soc": 0.0
        }
    },
    {
        "id": 3,
        "text": "为了防范恐怖主义和维护国家安全，政府有权监控公民的私人通讯。",
        "category": "国家安全",
        "weights": {
            "econ": 0.0,
            "soc": 1.0
        }
    },
    {
        "id": 4,
        "text": "没有被害人的行为（如自愿卖淫、赌博、吸食大麻）根本不应该被定性为犯罪。",
        "category": "个人自由",
        "weights": {
            "econ": 0.0,
            "soc": -1.0
        }
    },
    {
        "id": 5,
        "text": "医疗、教育和住房是基本人权，应当完全由国家保障，拒绝过度商业化。",
        "category": "经济福利",
        "weights": {
            "econ": -1.0,
            "soc": 0.0
        }
    },
    {
        "id": 6,
        "text": "慈善事业和民间互助足以解决大部分贫困问题，强制性的国家福利制度只会养懒汉。",
        "category": "经济福利",
        "weights": {
            "econ": 1.0,
            "soc": 0.0
        }
    },
    {
        "id": 7,
        "text": "维持传统的家庭价值观和道德观念，对一个国家的长治久安至关重要。",
        "category": "传统价值",
        "weights": {
            "econ": 0.0,
            "soc": 0.8
        }
    },
    {
        "id": 8,
        "text": "多文化主义是对社会的极大丰富，国家不应设有一种处于绝对统治地位的“官方文化”。",
        "category": "传统价值",
        "weights": {
            "econ": 0.0,
            "soc": -0.8
        }
    },
    {
        "id": 9,
        "text": "国家应当对大企业和高收入人群征收高额累进税和遗产税，以实现社会财富的重新分配。",
        "category": "税收制度",
        "weights": {
            "econ": -1.0,
            "soc": 0.0
        }
    },
    {
        "id": 10,
        "text": "政府发行的法定货币最终会导致通货膨胀，人们应该有权利自由使用加密货币或黄金作为替代。",
        "category": "市场自由",
        "weights": {
            "econ": 0.8,
            "soc": -0.5
        }
    },
    {
        "id": 11,
        "text": "强大的军事力量和坚固的国防是维护世界和平与国家尊严的唯一保障。",
        "category": "国家机器",
        "weights": {
            "econ": 0.0,
            "soc": 1.0
        }
    },
    {
        "id": 12,
        "text": "妇女应当拥有绝对的堕胎权利，政府或宗教团体在任何阶段都不应干涉这一选择。",
        "category": "个人自由",
        "weights": {
            "econ": 0.0,
            "soc": -1.0
        }
    },
    {
        "id": 13,
        "text": "工会应当在企业的管理和决策过程中拥有更大的话语权，甚至是部分否决权。",
        "category": "劳资关系",
        "weights": {
            "econ": -1.0,
            "soc": 0.0
        }
    },
    {
        "id": 14,
        "text": "最低工资法实际上干预了自由交易，导致企业缩减用工，反而伤害了低技能工人的就业机会。",
        "category": "劳资关系",
        "weights": {
            "econ": 1.0,
            "soc": 0.0
        }
    },
    {
        "id": 15,
        "text": "应当保留甚至扩大死刑的适用范围，以严惩那些犯下极其严重罪行的罪犯。",
        "category": "司法惩戒",
        "weights": {
            "econ": 0.0,
            "soc": 1.0
        }
    },
    {
        "id": 16,
        "text": "司法系统应当将重点放在罪犯的“教育和康复”上，而不是单纯的“惩罚和报复”。",
        "category": "司法惩戒",
        "weights": {
            "econ": 0.0,
            "soc": -1.0
        }
    },
    {
        "id": 17,
        "text": "土地、水和自然资源是全人类的共同财富，不应被私人随意买卖和垄断。",
        "category": "生态与产权",
        "weights": {
            "econ": -1.0,
            "soc": 0.0
        }
    },
    {
        "id": 18,
        "text": "企业的首要甚至唯一责任是对股东负责并创造利润，而不是承担所谓的“社会责任”。",
        "category": "生态与产权",
        "weights": {
            "econ": 1.0,
            "soc": 0.0
        }
    },
    {
        "id": 19,
        "text": "外来移民必须完全融入和接受本国的主流文化，否则就不应被允许定居。",
        "category": "民族与边境",
        "weights": {
            "econ": 0.0,
            "soc": 1.0
        }
    },
    {
        "id": 20,
        "text": "无论人们的出生地在哪里，只要他们愿意，就应该能够自由地跨越国界生活和工作（开放边境）。",
        "category": "民族与边境",
        "weights": {
            "econ": -0.5,
            "soc": -1.0
        }
    },
    {
        "id": 21,
        "text": "即使这意味着更高的税收和商品价格，国家也必须制定严苛的环保法规来应对气候变化。",
        "category": "生态与监管",
        "weights": {
            "econ": -0.8,
            "soc": 0.4
        }
    },
    {
        "id": 22,
        "text": "过度的环保法规会严重阻碍经济发展，保障人类社会的经济增长比保护原生生态环境更重要。",
        "category": "生态与监管",
        "weights": {
            "econ": 0.8,
            "soc": 0.0
        }
    },
    {
        "id": 23,
        "text": "学校应当强制学生穿着校服，并在日常课程中加入更多爱国主义和民族自豪感的教育。",
        "category": "教育与文化",
        "weights": {
            "econ": 0.0,
            "soc": 1.0
        }
    },
    {
        "id": 24,
        "text": "一个人有权自主决定自己的性别认同，并且社会和法律应当对此给予全面的接纳和保护。",
        "category": "教育与文化",
        "weights": {
            "econ": 0.0,
            "soc": -1.0
        }
    },
    {
        "id": 25,
        "text": "为了缩小极端的贫富差距，政府应当设定“最高工资限制”（即任何人的收入不应超过某个天花板）。",
        "category": "经济干预",
        "weights": {
            "econ": -1.0,
            "soc": 0.5
        }
    },
    {
        "id": 26,
        "text": "政府绝对不应该用纳税人的钱，去救助那些因为自身经营不善而濒临破产的大型企业（如银行、车企）。",
        "category": "经济干预",
        "weights": {
            "econ": 1.0,
            "soc": -0.3
        }
    },
    {
        "id": 27,
        "text": "警察在执法时需要更多的权力与豁免权，而不是被繁文缛节束缚住手脚。",
        "category": "国家机器",
        "weights": {
            "econ": 0.0,
            "soc": 1.0
        }
    },
    {
        "id": 28,
        "text": "身患绝症的人拥有绝对的权利去选择安乐死，以此体面地结束自己的生命。",
        "category": "个人自由",
        "weights": {
            "econ": 0.0,
            "soc": -1.0
        }
    },
    {
        "id": 29,
        "text": "软件、科学研究成果和救命的专利药物应当尽可能开源和免费，严苛的知识产权法阻碍了人类进步。",
        "category": "知识产权",
        "weights": {
            "econ": -0.8,
            "soc": -0.3
        }
    },
    {
        "id": 30,
        "text": "私有财产神圣不可侵犯，即使是为了所谓“公共利益”或基础设施建设，政府也不应强制征用。",
        "category": "知识产权",
        "weights": {
            "econ": 1.0,
            "soc": -0.5
        }
    },
    {
        "id": 31,
        "text": "对国家历史的负面事件过度反思和批判，会削弱社会的凝聚力和年轻人的爱国心。",
        "category": "历史与国家",
        "weights": {
            "econ": 0.0,
            "soc": 0.8
        }
    },
    {
        "id": 32,
        "text": "言论自由应当是绝对的，即便某些言论具有强烈的冒犯性或极端情绪，也不应受到政府审查。",
        "category": "言论自由",
        "weights": {
            "econ": 0.0,
            "soc": -1.0
        }
    },
    {
        "id": 33,
        "text": "全球化和自由贸易剥削了本国底层工人，国家应当采取关税保护主义来保护本土工业。",
        "category": "全球化",
        "weights": {
            "econ": -0.5,
            "soc": 0.5
        }
    },
    {
        "id": 34,
        "text": "自由贸易使得全球资源得到最优配置，取消关税和贸易壁垒对所有国家都是长期有利的。",
        "category": "全球化",
        "weights": {
            "econ": 1.0,
            "soc": -0.2
        }
    },
    {
        "id": 35,
        "text": "国家有义务通过审查互联网、影视和出版物，来保护社会大众（尤其是未成年人）免受不良信息的毒害。",
        "category": "言论自由",
        "weights": {
            "econ": 0.0,
            "soc": 1.0
        }
    },
    {
        "id": 36,
        "text": "即使在公立学校等世俗场所，也应当允许甚至鼓励一定程度的宗教传统或信仰教育。",
        "category": "宗教与社会",
        "weights": {
            "econ": 0.0,
            "soc": 0.8
        }
    },
    {
        "id": 37,
        "text": "自动化和人工智能带来的利润应作为“全民基本收入（UBI）”发放给全社会，而不是全归科技巨头所有。",
        "category": "未来经济",
        "weights": {
            "econ": -1.0,
            "soc": 0.0
        }
    },
    {
        "id": 38,
        "text": "对于那些严重破坏环境的企业高管，不仅要处以巨额罚款，还应剥夺其政治权利并追究刑事责任。",
        "category": "司法与商业",
        "weights": {
            "econ": -0.8,
            "soc": 0.6
        }
    },
    {
        "id": 39,
        "text": "在战争、疫情等重大危机时期，公民应当无条件服从国家的统一安排，哪怕需要牺牲部分个人权利。",
        "category": "危机应对",
        "weights": {
            "econ": 0.0,
            "soc": 1.0
        }
    },
    {
        "id": 40,
        "text": "总体而言，政府越小越好。最好的政府是管得最少的政府。",
        "category": "政府权力",
        "weights": {
            "econ": 0.8,
            "soc": -1.0
        }
    }
]